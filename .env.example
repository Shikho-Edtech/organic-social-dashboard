# Copy this to .env.local for local dev
# In Vercel: set these as Environment Variables in project settings

# Same service account JSON you used for GitHub Actions
GOOGLE_SHEETS_CREDS_JSON={"type":"service_account","project_id":"..."}

# Same spreadsheet ID you used for GitHub Actions
GOOGLE_SPREADSHEET_ID=1SZYrFUY1P_5YIAjcvnB3d-4oXwUyC-R1oCZ--IY-KgQ

# Choose a strong password for the dashboard
DASHBOARD_PASSWORD=your_strong_password_here

# Generate with: openssl rand -hex 32
AUTH_SECRET=random_32_byte_hex_string
